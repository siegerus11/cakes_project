{
    "name": "cakes_project",
    "private": true,
    "version": "1.0.0",
    "description": "The Cake Store App",
    "repository": {
        "type": "git",
        "url": "https://github.com/Siegerus/cakes_project"
    },
    "keywords": [
        "vite",
        "react"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build --emptyOutDir",
        "serve": "vite preview",
        "lint:eslint": "eslint . --ext .js,.tsx",
        "fix:eslint": "eslint --fix  . --ext .js,.tsx",
        "lint:stylelint": "stylelint **/*.{css,scss,jsx}",
        "fix:stylelint": "stylelint --fix  ./src/**/*.{css, scss,jsx}",
        "test": "jest",
        "format": "npx prettier . --write"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.11.2",
        "@types/geojson": "^7946.0.16",
        "@types/leaflet": "^1.9.21",
        "axios": "^1.16.1",
        "leaflet": "^1.9.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-draggable": "^4.5.0",
        "react-error-boundary": "^3.1.4",
        "react-leaflet": "^4.2.1",
        "react-redux": "^9.2.0",
        "react-router-dom": "^6.3.0",
        "react-toastify": "^11.1.0",
        "sass": "^1.54.5",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@babel/core": "^7.18.13",
        "@babel/preset-react": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@namics/stylelint-bem": "^7.0.0",
        "@stylelint/postcss-css-in-js": "^0.38.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitejs/plugin-react": "^2.0.1",
        "autoprefixer": "^10.4.8",
        "axios-mock-adapter": "^2.1.0",
        "babel-loader": "^8.2.5",
        "eslint": "^8.57.1",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-import": "2.26.0",
        "eslint-plugin-jest": "27.0.1",
        "eslint-plugin-jsx-a11y": "6.6.1",
        "eslint-plugin-react": "^7.31.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-unused-imports": "^2.0.0",
        "identity-obj-proxy": "^3.0.0",
        "identity-proxy": "^0.0.1",
        "jest": "^29.0.1",
        "jest-environment-jsdom": "^30.4.1",
        "postcss": "^8.4.16",
        "postcss-scss": "^4.0.4",
        "postcss-syntax": "^0.36.2",
        "prettier": "^2.7.1",
        "prettier-plugin-style-order": "^0.2.2",
        "react-test-renderer": "^18.2.0",
        "stylelint": "^14.11.0",
        "stylelint-config-idiomatic-order": "^8.1.0",
        "stylelint-config-prettier-scss": "^0.0.1",
        "stylelint-config-standard-scss": "^5.0.0",
        "stylelint-scss": "^4.3.0",
        "ts-jest": "^29.4.11",
        "typescript": "^4.8.2",
        "vite": "^3.0.9",
        "webpack": "^5.74.0"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "transform": {
            "^.+\\.(ts|tsx)$": [
                "ts-jest",
                {
                    "tsconfig": "tsconfig.json"
                }
            ]
        },
        "moduleNameMapper": {
            "\\.(css|scss|module\\.scss)$": "identity-obj-proxy"
        },
        "setupFilesAfterEnv": [
            "@testing-library/jest-dom"
        ]
    }
}
