{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"target": "ESNext",
		"useDefineForClassFields": true,
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": false,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"moduleResolution": "Node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"types": ["@testing-library/jest-dom", "jest", "node", "react", "react-dom"]
		/* "typeRoots": ["./node_modules", "./types"] */
	},
	"include": ["src", "vite-env.d.ts", "scss.d.ts", "css.d.ts", "vite.config.js", "postcss.config.js", "babel.config.js", "jest.config.js"]
}